# ==============================================================================
# Unorive Environment Variables Template
# Copy this file to '.env' and fill in your actual values.
# IMPORTANT: Never commit the '.env' file to version control.
# ==============================================================================

# Mapbox Configuration
MAPBOX_ACCESS_TOKEN=your_mapbox_public_access_token_here
MAPBOX_DOWNLOADS_TOKEN=your_mapbox_secret_downloads_token_here

# Firebase Configuration (Placeholders until configured via flutterfire)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_PROJECT_ID=unorive-placeholder
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
FIREBASE_APP_ID_ANDROID=1:1234567890:android:abcdef123456
FIREBASE_APP_ID_IOS=1:1234567890:ios:abcdef123456
FIREBASE_MEASUREMENT_ID=G-MEASUREMENTID
